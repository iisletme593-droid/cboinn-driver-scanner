<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cboinn Driver Scanner"
        Height="760" Width="1180"
        MinHeight="640" MinWidth="980"
        WindowStartupLocation="CenterScreen"
        Background="#FFF3F4F6"
        FontFamily="Segoe UI">
  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <!-- Başlık -->
    <Border Grid.Row="0" Background="#FF111827" Padding="18,14">
      <StackPanel Orientation="Horizontal">
        <Image x:Name="LogoImg" Height="48" Margin="0,0,14,0" VerticalAlignment="Center" Stretch="Uniform" SnapsToDevicePixels="True"/>
        <StackPanel VerticalAlignment="Center">
          <TextBlock Text="Cboinn Driver Scanner" Foreground="White" FontSize="20" FontWeight="Bold"/>
          <TextBlock Text="Sürücü (Windows Update) ve program (winget) güncelleyici"
                     Foreground="#FF9CA3AF" FontSize="12" Margin="0,2,0,0"/>
        </StackPanel>
        <Border x:Name="AdminBadge" Background="#FF374151" CornerRadius="4" Padding="9,5" Margin="22,0,0,0" VerticalAlignment="Center">
          <TextBlock x:Name="AdminBadgeText" Text="..." Foreground="White" FontSize="11"/>
        </Border>
        <Button x:Name="BtnAdmin" Content="Yönetici Olarak Başlat" Padding="10,5" Margin="10,0,0,0" VerticalAlignment="Center" Visibility="Collapsed"/>
      </StackPanel>
    </Border>

    <!-- Yeniden başlatma uyarı şeridi -->
    <Border x:Name="RebootBanner" Grid.Row="1" Background="#FFB91C1C" Padding="14,8" Visibility="Collapsed">
      <TextBlock x:Name="RebootBannerText" Foreground="White" FontWeight="SemiBold"
                 Text="Bekleyen bir yeniden başlatma var. Güncellemelerin tamamlanması için bilgisayarı yeniden başlatın."/>
    </Border>

    <!-- Eylem çubuğu -->
    <Border Grid.Row="2" Background="White" Padding="14,10" BorderBrush="#FFE5E7EB" BorderThickness="0,0,0,1">
      <StackPanel Orientation="Horizontal">
        <Button x:Name="BtnScanAll" Content="Her Şeyi Tara" Padding="16,8" Margin="0,0,8,0"
                Background="#FF2563EB" Foreground="White" FontWeight="SemiBold" BorderThickness="0" Cursor="Hand"/>
        <Button x:Name="BtnApplyRecommended" Content="Önerilenleri Uygula" Padding="16,8" Margin="0,0,8,0"
                Background="#FF059669" Foreground="White" FontWeight="SemiBold" BorderThickness="0" Cursor="Hand"/>
        <Button x:Name="BtnBackup" Content="Sürücüleri Yedekle" Padding="12,8" Margin="0,0,8,0"/>
        <Button x:Name="BtnHtml" Content="HTML Rapor" Padding="12,8" Margin="0,0,8,0"/>
        <Button x:Name="BtnClearData" Content="Verileri Temizle" Padding="12,8" Margin="0,0,8,0"/>
        <Button x:Name="BtnCancel" Content="İptal" Padding="12,8" Margin="0,0,8,0" IsEnabled="False"/>
        <TextBlock Text="Filtre:" VerticalAlignment="Center" Margin="16,0,6,0" Foreground="#FF374151"/>
        <TextBox x:Name="TxtFilter" Width="220" Padding="6,4" VerticalContentAlignment="Center"/>
      </StackPanel>
    </Border>

    <!-- İçerik -->
    <TabControl Grid.Row="3" Margin="10" x:Name="Tabs" Background="Transparent" BorderThickness="0">

      <!-- GENEL BAKIŞ -->
      <TabItem Header="Genel Bakış">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
          <Grid Margin="4,8,4,4">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="White" BorderBrush="#FFE5E7EB" BorderThickness="1" CornerRadius="6" Margin="0,0,6,0" Padding="16">
              <StackPanel>
                <TextBlock Text="Sistem Bilgisi" FontWeight="Bold" FontSize="15" Margin="0,0,0,10"/>
                <TextBlock x:Name="TxtSysName" Margin="0,2,0,2"/>
                <TextBlock x:Name="TxtSysOS"   Margin="0,2,0,2" TextWrapping="Wrap"/>
                <TextBlock x:Name="TxtSysCpu"  Margin="0,2,0,2" TextWrapping="Wrap"/>
                <TextBlock x:Name="TxtSysRam"  Margin="0,2,0,2"/>
                <TextBlock x:Name="TxtSysDisk" Margin="0,2,0,2"/>
                <TextBlock x:Name="TxtSysGpu"  Margin="0,2,0,2" TextWrapping="Wrap"/>
                <TextBlock x:Name="TxtSysBoot" Margin="0,2,0,2"/>
              </StackPanel>
            </Border>

            <StackPanel Grid.Column="1" Margin="6,0,0,0">
              <Border Background="White" BorderBrush="#FFE5E7EB" BorderThickness="1" CornerRadius="6" Padding="16">
                <StackPanel>
                  <TextBlock Text="Durum" FontWeight="Bold" FontSize="15" Margin="0,0,0,10"/>
                  <TextBlock x:Name="TxtCardDrivers"  Margin="0,2,0,2" FontSize="13"/>
                  <TextBlock x:Name="TxtCardPrograms" Margin="0,2,0,2" FontSize="13"/>
                  <TextBlock x:Name="TxtCardOld"      Margin="0,2,0,2" FontSize="13"/>
                  <TextBlock x:Name="TxtCardReboot"   Margin="0,2,0,2" FontSize="13"/>
                  <TextBlock x:Name="TxtCardRestore"  Margin="0,2,0,2" FontSize="13"/>
                </StackPanel>
              </Border>
              <Border Background="White" BorderBrush="#FFE5E7EB" BorderThickness="1" CornerRadius="6" Padding="16" Margin="0,8,0,0">
                <StackPanel>
                  <TextBlock Text="Öneri" FontWeight="Bold" FontSize="15"/>
                  <TextBlock x:Name="TxtRecommend" TextWrapping="Wrap" Margin="0,6,0,0" Foreground="#FF374151"
                             Text="Başlamak için 'Her Şeyi Tara'ya tıklayın. Ardından 'Önerilenleri Uygula' ile donanımınıza uygun tüm güncellemeleri tek seferde kurabilirsiniz."/>
                </StackPanel>
              </Border>
            </StackPanel>
          </Grid>
        </ScrollViewer>
      </TabItem>

      <!-- SÜRÜCÜ GÜNCELLEMELERİ -->
      <TabItem Header="Sürücü Güncellemeleri">
        <Grid Margin="0,8,0,0">
          <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
          </Grid.RowDefinitions>
          <DataGrid x:Name="GridUpdates" Grid.Row="0" AutoGenerateColumns="False" IsReadOnly="True"
                    SelectionMode="Extended" GridLinesVisibility="Horizontal" HeadersVisibility="Column"
                    RowHeight="30" Background="White" RowBackground="White" AlternatingRowBackground="#FFF9FAFB"
                    CanUserAddRows="False" BorderBrush="#FFE5E7EB" BorderThickness="1">
            <DataGrid.Columns>
              <DataGridTextColumn Header="Aygıt / Güncelleme" Binding="{Binding MatchedDevice}" Width="2.2*"/>
              <DataGridTextColumn Header="Sağlayıcı" Binding="{Binding Provider}" Width="1*"/>
              <DataGridTextColumn Header="Sınıf" Binding="{Binding DriverClass}" Width="0.9*"/>
              <DataGridTextColumn Header="Mevcut Sürüm" Binding="{Binding CurrentVersion}" Width="1*"/>
              <DataGridTextColumn Header="Mevcut Tarih" Binding="{Binding CurrentDate}" Width="0.8*"/>
              <DataGridTextColumn Header="Önerilen Tarih" Binding="{Binding NewDate}" Width="0.8*"/>
              <DataGridTextColumn Header="Boyut (MB)" Binding="{Binding SizeMB}" Width="0.7*"/>
            </DataGrid.Columns>
          </DataGrid>
          <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,10,0,0">
            <Button x:Name="BtnScan" Content="Sürücüleri Tara" Padding="12,8" Margin="0,0,8,0"/>
            <Button x:Name="BtnInstallSel" Content="Seçilenleri Yükle" Padding="14,8" Margin="0,0,8,0"
                    Background="#FF059669" Foreground="White" FontWeight="SemiBold" BorderThickness="0" Cursor="Hand"/>
            <Button x:Name="BtnInstallAll" Content="Tümünü Yükle" Padding="12,8" Margin="0,0,8,0"/>
            <Button x:Name="BtnSelAllUpd" Content="Tümünü Seç" Padding="12,8" Margin="0,0,8,0"/>
            <Button x:Name="BtnCatalog" Content="Update Kataloğunda Aç" Padding="12,8" Margin="0,0,8,0"/>
            <CheckBox x:Name="ChkRestore" Content="Önce geri yükleme noktası" IsChecked="True" VerticalAlignment="Center" Margin="14,0,0,0" Foreground="#FF374151"/>
          </StackPanel>
        </Grid>
      </TabItem>

      <!-- TÜM SÜRÜCÜLER -->
      <TabItem Header="Tüm Sürücüler">
        <Grid Margin="0,8,0,0">
          <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
          </Grid.RowDefinitions>
          <DataGrid x:Name="GridInventory" Grid.Row="0" AutoGenerateColumns="False" IsReadOnly="True"
                    GridLinesVisibility="Horizontal" HeadersVisibility="Column" RowHeight="28"
                    Background="White" RowBackground="White" AlternatingRowBackground="#FFF9FAFB"
                    CanUserAddRows="False" BorderBrush="#FFE5E7EB" BorderThickness="1">
            <DataGrid.Columns>
              <DataGridTextColumn Header="Aygıt" Binding="{Binding DeviceName}" Width="2.2*"/>
              <DataGridTextColumn Header="Sınıf" Binding="{Binding DeviceClass}" Width="1*"/>
              <DataGridTextColumn Header="Sağlayıcı" Binding="{Binding Provider}" Width="1.1*"/>
              <DataGridTextColumn Header="Sürüm" Binding="{Binding Version}" Width="1*"/>
              <DataGridTextColumn Header="Tarih" Binding="{Binding Date}" Width="0.8*"/>
              <DataGridTextColumn Header="Yaş (yıl)" Binding="{Binding AgeYears}" Width="0.6*"/>
              <DataGridTextColumn Header="İncelenmeli?" Binding="{Binding OldText}" Width="0.7*"/>
            </DataGrid.Columns>
          </DataGrid>
          <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,10,0,0">
            <Button x:Name="BtnRefresh" Content="Envanteri Yenile" Padding="12,8" Margin="0,0,8,0"/>
            <CheckBox x:Name="ChkOldOnly" Content="İncelenmesi önerilenler (4+ yıl, üretici)" VerticalAlignment="Center" Margin="6,0,0,0" Foreground="#FF374151"/>
            <TextBlock Text="(Sürücü tarihi tek başına güncellik kanıtı değildir; üretici desteğini kontrol edin.)"
                       VerticalAlignment="Center" Margin="14,0,0,0" Foreground="#FF6B7280" FontSize="11"/>
          </StackPanel>
        </Grid>
      </TabItem>

      <!-- PROGRAMLAR -->
      <TabItem Header="Programlar (Yazılım)">
        <Grid Margin="0,8,0,0">
          <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
          </Grid.RowDefinitions>
          <DataGrid x:Name="GridSoftware" Grid.Row="0" AutoGenerateColumns="False" IsReadOnly="True"
                    SelectionMode="Extended" GridLinesVisibility="Horizontal" HeadersVisibility="Column"
                    RowHeight="30" Background="White" RowBackground="White" AlternatingRowBackground="#FFF9FAFB"
                    CanUserAddRows="False" BorderBrush="#FFE5E7EB" BorderThickness="1">
            <DataGrid.Columns>
              <DataGridTextColumn Header="Program" Binding="{Binding Name}" Width="2.4*"/>
              <DataGridTextColumn Header="Kimlik (winget Id)" Binding="{Binding Id}" Width="1.6*"/>
              <DataGridTextColumn Header="Mevcut Sürüm" Binding="{Binding Version}" Width="1*"/>
              <DataGridTextColumn Header="Önerilen Sürüm" Binding="{Binding Available}" Width="1*"/>
              <DataGridTextColumn Header="Kaynak" Binding="{Binding Source}" Width="0.7*"/>
            </DataGrid.Columns>
          </DataGrid>
          <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,10,0,0">
            <Button x:Name="BtnSwScan" Content="Programları Tara" Padding="12,8" Margin="0,0,8,0"/>
            <Button x:Name="BtnSwUpdateSel" Content="Seçilenleri Güncelle" Padding="14,8" Margin="0,0,8,0"
                    Background="#FF059669" Foreground="White" FontWeight="SemiBold" BorderThickness="0" Cursor="Hand"/>
            <Button x:Name="BtnSwUpdateAll" Content="Tümünü Güncelle" Padding="12,8" Margin="0,0,8,0"/>
            <Button x:Name="BtnSelAllSw" Content="Tümünü Seç" Padding="12,8" Margin="0,0,8,0"/>
          </StackPanel>
        </Grid>
      </TabItem>

      <!-- GÜNLÜK -->
      <TabItem Header="Günlük">
        <Grid Margin="0,8,0,0">
          <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
          </Grid.RowDefinitions>
          <TextBox x:Name="TxtLog" Grid.Row="0" IsReadOnly="True" TextWrapping="NoWrap" FontFamily="Consolas" FontSize="12"
                   VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                   Background="White" BorderBrush="#FFE5E7EB" BorderThickness="1"/>
          <Button x:Name="BtnClearLog" Grid.Row="1" Content="Günlüğü Temizle" Padding="12,6" Margin="0,8,0,0" HorizontalAlignment="Left"/>
        </Grid>
      </TabItem>
    </TabControl>

    <!-- Durum çubuğu -->
    <Border Grid.Row="4" Background="White" BorderBrush="#FFE5E7EB" BorderThickness="0,1,0,0" Padding="14,8">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="280"/>
        </Grid.ColumnDefinitions>
        <TextBlock x:Name="TxtStatus" Grid.Column="0" Text="Hazır." VerticalAlignment="Center" Foreground="#FF374151"/>
        <ProgressBar x:Name="Bar" Grid.Column="1" Height="14" Minimum="0" Maximum="100" Value="0"/>
      </Grid>
    </Border>
  </Grid>
</Window>
